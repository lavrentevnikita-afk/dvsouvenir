NUXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=souvenir
POSTGRES_PASSWORD=souvenir
POSTGRES_DB=souvenir

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Node Environment
NODE_ENV=development

# S3 Object Storage (Yandex Cloud)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=your_bucket_name
S3_PUBLIC_BASE_URL=https://storage.yandexcloud.net/your_bucket_name
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key

# Optional: Admin accounts (auto-created on startup)
ADMIN_PASSWORD=Admin123!
MANAGER_PASSWORD=Manager123!

# Email SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="Suvlavka" <noreply@suvlavka.com>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000
